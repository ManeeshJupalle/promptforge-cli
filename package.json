{
  "name": "promptforge",
  "version": "0.1.0",
  "description": "Jest for prompts — a local-first, multi-provider testing framework for LLM apps. Write assertions, catch regressions, ship with confidence.",
  "keywords": [
    "llm",
    "prompt",
    "prompts",
    "testing",
    "test",
    "evals",
    "evaluation",
    "ai",
    "anthropic",
    "claude",
    "openai",
    "gpt",
    "gemini",
    "ollama",
    "local-first",
    "cli",
    "typescript"
  ],
  "license": "MIT",
  "author": "PromptForge contributors",
  "homepage": "https://github.com/ManeeshJupalle/PromptForge#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ManeeshJupalle/PromptForge.git"
  },
  "bugs": {
    "url": "https://github.com/ManeeshJupalle/PromptForge/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "promptforge": "./bin/promptforge"
  },
  "scripts": {
    "build": "npm run build:cli && npm run build:dashboard",
    "build:cli": "tsup",
    "build:dashboard": "vite build",
    "dev": "tsup --watch",
    "dev:dashboard": "vite",
    "start": "node ./bin/promptforge",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.3",
    "@google/generative-ai": "^0.21.0",
    "@hono/node-server": "^1.13.2",
    "@inquirer/prompts": "^7.0.0",
    "@xenova/transformers": "^2.17.2",
    "ajv": "^8.17.1",
    "better-sqlite3": "^12.9.0",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "diff": "^9.0.0",
    "glob": "^10.3.10",
    "hono": "^4.6.3",
    "js-yaml": "^4.1.0",
    "nanoid": "^5.0.7",
    "open": "^10.1.0",
    "openai": "^4.65.0",
    "ora": "^8.1.0",
    "react": "^18.3.1",
    "react-diff-viewer-continued": "^3.4.0",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "tsx": "^4.19.1",
    "wouter": "^3.3.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^5.2.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
    "vite": "^5.4.8"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "protobufjs": "^7.5.5"
  }
}
